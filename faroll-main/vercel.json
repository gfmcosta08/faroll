{
  "headers": [
    {
      "source": "/",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate, s-maxage=0" },
        { "key": "CDN-Cache-Control", "value": "no-store" },
        { "key": "Vercel-CDN-Cache-Control", "value": "no-store" }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate, s-maxage=0" },
        { "key": "CDN-Cache-Control", "value": "no-store" },
        { "key": "Vercel-CDN-Cache-Control", "value": "no-store" }
      ]
    },
    {
      "source": "/config.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate, s-maxage=0" },
        { "key": "CDN-Cache-Control", "value": "no-store" },
        { "key": "Vercel-CDN-Cache-Control", "value": "no-store" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/app/saude", "destination": "https://psicoapp-eosin.vercel.app/app/saude" },
    { "source": "/app/saude/(.*)", "destination": "https://psicoapp-eosin.vercel.app/app/saude/$1" },
    { "source": "/app/imoveis", "destination": "https://dashboard-coral-two-64.vercel.app/app/imoveis" },
    { "source": "/app/imoveis/(.*)", "destination": "https://dashboard-coral-two-64.vercel.app/app/imoveis/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
